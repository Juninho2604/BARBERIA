# Copia este archivo a apps/api/.env (no se commitea) y rellena los valores.
# En producción estos valores viven en el VPS, nunca en el repo.

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Base de datos (Postgres del docker-compose local)
DATABASE_URL=postgresql://barberia:barberia_dev@localhost:5432/barberia?schema=public

# CORS — orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:3000

# Auth — generar con `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-dev-only
JWT_REFRESH_SECRET=change-me-dev-only
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Negocio
DEFAULT_TIMEZONE=America/Caracas
SLOT_GRANULARITY_MINUTES=30
